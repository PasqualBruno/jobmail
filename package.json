{
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "setup": "npm install && cd server && npm install && npx prisma generate && cd ../client && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "check": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js"
  }
}
